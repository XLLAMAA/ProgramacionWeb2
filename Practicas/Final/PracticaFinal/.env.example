# ===== ENTORNO =====
NODE_ENV=development

# ===== SERVIDOR =====
PORT=3000
CORS_ORIGIN=http://localhost:3000

# ===== DATABASE =====
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/bildyapp?retryWrites=true&w=majority

# ===== JWT - Access Token =====
JWT_ACCESS_SECRET=PonAquiUnaCadenaDeTextoMuyLargaYAleatoria123!
JWT_ACCESS_EXPIRES_IN=15m

# ===== JWT - Refresh Token =====
JWT_REFRESH_SECRET=OtraCadenaDeTextoMuyLargaYAleatoria456!
JWT_REFRESH_EXPIRES_IN=7d

# ===== MULTER - Subida de archivos =====
MULTER_UPLOAD_DIR=./uploads
MULTER_MAX_FILE_SIZE=5242880

# ===== CLOUDINARY - Almacenamiento en nube =====
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ===== NODEMAILER - Envío de emails =====
MAIL_SERVICE=gmail
MAIL_USER=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password
MAIL_FROM=noreply@bildyapp.com

# ===== SLACK - Webhooks para errores =====
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/TU/WEBHOOK/URL
